# Copy to .env (which is gitignored) OR set these as Colab secrets.
# NEVER commit real tokens. The code reads these from the environment only.

# Hugging Face token (read for gated models, write for Hub push during export).
HF_TOKEN=

# Weights & Biases (optional). If unset, training falls back to TensorBoard.
WANDB_API_KEY=
WANDB_PROJECT=clinical-scribe
WANDB_ENTITY=

# Where to checkpoint on Colab. Point at mounted Drive for crash resilience, e.g.
# /content/drive/MyDrive/clinical-scribe/outputs
CLINICAL_SCRIBE_OUTPUT_DIR=outputs
